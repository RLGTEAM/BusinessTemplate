---
interface Props {
  title: string;
  subtitle?: string;
}

const { title, subtitle } = Astro.props;
---

<div class="mb-12 max-w-2xl" data-reveal>
  <h2 class="text-3xl font-bold text-secondary sm:text-4xl">{title}</h2>
  {subtitle && <p class="mt-3 text-lg text-ink-muted">{subtitle}</p>}
</div>
