---
/**
 * THE per-client creative sandbox — a full custom section, rendered wherever
 * "signature" appears in design.sectionOrder. Contract: docs/CREATIVE-CONTRACT.md.
 *
 * In the template this renders nothing. On a client site, replace the body
 * below with the signature concept (custom markup, inline SVG, GSAP hooks via
 * src/components/custom/signature.ts). Copy comes from content.signature,
 * colors from tokens, direction from logical properties — same rules as
 * every other section, unlimited creativity inside them.
 */
import { getBusiness } from "@/lib/business";

const business = await getBusiness();
const signature = business.content.signature;
---

{
  signature && (
    <section id="signature" class="scroll-mt-20 section-pad">
      {/* Replace with the client's signature moment. signature.title and
          signature.strings.* hold every string you may render. */}
    </section>
  )
}
