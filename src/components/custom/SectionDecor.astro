---
/**
 * Per-section decorative layer — rendered as the first child of EVERY content
 * section, so a client's creative concept can permeate the whole page
 * (docs/CREATIVE-CONTRACT.md). Branch on the `section` prop to give each
 * section its own expression of the ONE concept.
 *
 * Section roots are `relative isolate`, so:
 *   - `absolute inset-0 -z-10 pointer-events-none` → art BEHIND the content
 *     but above the section's background color;
 *   - `absolute inset-0 pointer-events-none opacity-*` → subtle overlay
 *     (grain, particles) ON TOP of content.
 *
 * The template ships this as a no-op. Decorative only: aria-hidden,
 * pointer-events-none, token colors, no strings unless from content.signature.
 */
interface Props {
  /** Which section this instance decorates, e.g. "services", "cta". */
  section: string;
}
---
