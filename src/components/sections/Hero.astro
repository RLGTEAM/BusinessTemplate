---
import { Image } from "astro:assets";
import Button from "@/components/ui/Button.astro";
import Container from "@/components/ui/Container.astro";
import { getBusiness, resolveHref } from "@/lib/business";
import { resolveImage } from "@/lib/images";

const business = await getBusiness();
const { hero } = business.content;
const heroImage = resolveImage(hero.image.src);
---

<section class="hero-bg overflow-hidden py-16 sm:py-24">
  <Container class="grid items-center gap-12 lg:grid-cols-2">
    <div class="max-w-xl">
      {
        hero.eyebrow && (
          <p class="mb-4 inline-block rounded-full bg-surface-alt px-4 py-1.5 text-sm font-semibold text-primary">
            {hero.eyebrow}
          </p>
        )
      }
      <h1 class="text-4xl font-bold leading-tight text-secondary sm:text-5xl lg:text-6xl">
        {hero.headline}
      </h1>
      <p class="mt-5 text-lg text-ink-muted sm:text-xl">{hero.subheadline}</p>
      <div class="mt-8 flex flex-wrap gap-4">
        <Button href={resolveHref(hero.primaryCta.href, business)}>{hero.primaryCta.label}</Button>
        {
          hero.secondaryCta && (
            <Button href={resolveHref(hero.secondaryCta.href, business)} variant="outline">
              {hero.secondaryCta.label}
            </Button>
          )
        }
      </div>
    </div>

    <div data-reveal="slide-end">
      <Image
        src={heroImage}
        alt={hero.image.alt}
        widths={[480, 800, 1200]}
        sizes="(max-width: 1023px) 100vw, 50vw"
        loading="eager"
        fetchpriority="high"
        class="w-full rounded-card object-cover shadow-card"
      />
    </div>
  </Container>
</section>

<style>
  .hero-bg {
    /* --angle-brand mirrors automatically in RTL (see global.css). */
    background-image: linear-gradient(
      var(--angle-brand),
      color-mix(in oklab, var(--color-primary) 8%, var(--color-surface)),
      var(--color-surface) 55%
    );
  }
</style>
