---
import SectionDecor from "@/components/custom/SectionDecor.astro";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import { getBusiness } from "@/lib/business";

const business = await getBusiness();
const { faq } = business.content;
---

<section id="faq" class="relative isolate scroll-mt-20 section-pad">
  <SectionDecor section="faq" />
  <Container class="max-w-3xl">
    <SectionHeading title={faq.title} subtitle={faq.subtitle} />
    <div class="space-y-4" data-reveal-group>
      {
        faq.items.map((item) => (
          <details class="group rounded-card border border-line bg-surface p-1 shadow-card">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 rounded-card px-5 py-4 font-semibold text-secondary [&::-webkit-details-marker]:hidden">
              {item.question}
              <svg
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                aria-hidden="true"
                class="shrink-0 text-primary transition-transform duration-200 group-open:rotate-180"
              >
                <path d="m6 9 6 6 6-6" />
              </svg>
            </summary>
            <p class="px-5 pb-5 text-ink-muted">{item.answer}</p>
          </details>
        ))
      }
    </div>
  </Container>
</section>
