---
import SectionDecor from "@/components/custom/SectionDecor.astro";
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import { getBusiness } from "@/lib/business";

const business = await getBusiness();
const { services } = business.data;
const copy = business.content.services;

interface Props {
  /** Layout variant — a composition-time choice made in index.astro. */
  layout?: "cards" | "list" | "panels";
}
const { layout = "cards" } = Astro.props;
---

<section id="services" class="relative isolate scroll-mt-20 section-pad">
  <SectionDecor section="services" />
  <Container>
    <SectionHeading title={copy.title} subtitle={copy.subtitle} />

    {
      layout === "cards" && (
        <ul class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4" data-reveal-group>
          {services.map((service) => (
            <li class="flex flex-col rounded-card border border-line bg-surface p-6 shadow-card transition-shadow hover:shadow-card-hover">
              <h3 class="text-xl font-bold text-secondary">{service.title}</h3>
              <p class="mt-3 flex-1 text-ink-muted">{service.description}</p>
              {service.price && (
                <p class="mt-5 font-semibold text-primary">
                  <bdi>{service.price}</bdi>
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }

    {
      layout === "list" && (
        <ul class="divide-y divide-line border-y border-line" data-reveal-group>
          {services.map((service) => (
            <li class="flex flex-col gap-2 py-6 sm:flex-row sm:items-baseline sm:justify-between sm:gap-8">
              <div class="max-w-2xl">
                <h3 class="text-xl font-bold text-secondary">{service.title}</h3>
                <p class="mt-2 text-ink-muted">{service.description}</p>
              </div>
              {service.price && (
                <p class="shrink-0 text-lg font-semibold text-primary">
                  <bdi>{service.price}</bdi>
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }

    {
      layout === "panels" && (
        <ul class="grid gap-6 sm:grid-cols-2" data-reveal-group>
          {services.map((service, index) => (
            <li class="relative overflow-hidden rounded-card bg-surface-alt p-8">
              <span
                aria-hidden="true"
                class="pointer-events-none absolute -top-4 end-4 font-display text-8xl font-bold text-secondary/10"
              >
                <bdi class="force-ltr">{String(index + 1).padStart(2, "0")}</bdi>
              </span>
              <h3 class="relative text-2xl font-bold text-secondary">{service.title}</h3>
              <p class="relative mt-3 max-w-md text-ink-muted">{service.description}</p>
              {service.price && (
                <p class="relative mt-5 font-semibold text-primary">
                  <bdi>{service.price}</bdi>
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </Container>
</section>
