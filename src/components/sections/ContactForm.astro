---
import Container from "@/components/ui/Container.astro";
import SectionHeading from "@/components/ui/SectionHeading.astro";
import { getBusiness } from "@/lib/business";

const business = await getBusiness();
const copy = business.content.contactForm;

const fields = [
  { id: "name", name: "name", type: "text", label: copy.nameLabel, autocomplete: "name" },
  { id: "email", name: "email", type: "email", label: copy.emailLabel, autocomplete: "email" },
  { id: "phone", name: "phone", type: "tel", label: copy.phoneLabel, autocomplete: "tel" },
] as const;
---

<section id="contact" class="scroll-mt-20 bg-surface-alt py-16 sm:py-24">
  <Container class="max-w-2xl">
    <SectionHeading title={copy.title} subtitle={copy.subtitle} />

    <form
      id="contact-form"
      class="space-y-6 rounded-card border border-line bg-surface p-6 shadow-card sm:p-8"
      novalidate
      data-reveal
      data-sending-label={copy.sendingLabel}
      data-submit-label={copy.submitLabel}
      data-success-message={copy.successMessage}
      data-error-message={copy.errorMessage}
      data-required-error={copy.requiredError}
      data-email-error={copy.emailError}
      data-subject={`${copy.title} — ${business.data.name}`}
    >
      {/* Honeypot — hidden from humans, screen readers, and tab order. */}
      <input
        type="checkbox"
        name="botcheck"
        tabindex="-1"
        aria-hidden="true"
        class="pointer-events-none absolute size-px opacity-0"
      />

      {
        fields.map((field) => (
          <div>
            <label for={field.id} class="mb-1.5 block font-medium text-secondary">
              {field.label}
            </label>
            <input
              id={field.id}
              name={field.name}
              type={field.type}
              autocomplete={field.autocomplete}
              required
              dir={field.type === "text" ? undefined : "ltr"}
              class:list={[
                "min-h-12 w-full rounded-md border border-line bg-surface px-4 py-2.5 text-ink transition-colors focus:border-primary focus:outline-none",
                field.type !== "text" && "text-start",
              ]}
              aria-describedby={`${field.id}-error`}
            />
            <p id={`${field.id}-error`} class="mt-1.5 hidden text-sm text-red-700" data-field-error />
          </div>
        ))
      }

      <div>
        <label for="message" class="mb-1.5 block font-medium text-secondary">
          {copy.messageLabel}
        </label>
        <textarea
          id="message"
          name="message"
          rows="4"
          required
          class="w-full rounded-md border border-line bg-surface px-4 py-2.5 text-ink transition-colors focus:border-primary focus:outline-none"
          aria-describedby="message-error"></textarea>
        <p id="message-error" class="mt-1.5 hidden text-sm text-red-700" data-field-error></p>
      </div>

      <button
        type="submit"
        class="inline-flex min-h-12 w-full items-center justify-center rounded-full bg-primary px-7 py-3 font-semibold text-surface shadow-card transition-colors hover:bg-secondary disabled:cursor-not-allowed disabled:opacity-60 sm:w-auto"
      >
        {copy.submitLabel}
      </button>

      <p id="form-status" class="hidden rounded-md px-4 py-3 font-medium" role="status" aria-live="polite">
      </p>
    </form>
  </Container>
</section>

<script>
  import { PUBLIC_WEB3FORMS_KEY } from "astro:env/client";

  const EMAIL_PATTERN = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

  function fieldError(input: HTMLInputElement | HTMLTextAreaElement, form: HTMLFormElement): string {
    if (input.value.trim() === "") return form.dataset.requiredError ?? "";
    if (input.type === "email" && !EMAIL_PATTERN.test(input.value)) {
      return form.dataset.emailError ?? "";
    }
    return "";
  }

  function validate(form: HTMLFormElement): boolean {
    let firstInvalid: HTMLElement | null = null;
    for (const input of form.querySelectorAll<HTMLInputElement | HTMLTextAreaElement>(
      "input[required], textarea[required]",
    )) {
      const message = fieldError(input, form);
      const errorEl = document.getElementById(`${input.id}-error`);
      if (errorEl) {
        errorEl.textContent = message;
        errorEl.classList.toggle("hidden", message === "");
      }
      input.setAttribute("aria-invalid", message === "" ? "false" : "true");
      if (message !== "" && !firstInvalid) firstInvalid = input;
    }
    firstInvalid?.focus();
    return firstInvalid === null;
  }

  function showStatus(form: HTMLFormElement, kind: "success" | "error"): void {
    const status = form.querySelector<HTMLElement>("#form-status");
    if (!status) return;
    status.textContent =
      kind === "success" ? (form.dataset.successMessage ?? "") : (form.dataset.errorMessage ?? "");
    status.classList.remove("hidden");
    status.classList.toggle("bg-green-100", kind === "success");
    status.classList.toggle("text-green-900", kind === "success");
    status.classList.toggle("bg-red-100", kind === "error");
    status.classList.toggle("text-red-900", kind === "error");
  }

  async function submit(form: HTMLFormElement): Promise<void> {
    const button = form.querySelector<HTMLButtonElement>("button[type=submit]");
    if (!button) return;

    button.disabled = true;
    button.textContent = form.dataset.sendingLabel ?? "";
    try {
      const formData = new FormData(form);
      formData.append("access_key", PUBLIC_WEB3FORMS_KEY);
      formData.append("subject", form.dataset.subject ?? "");
      const response = await fetch("https://api.web3forms.com/submit", {
        method: "POST",
        body: formData,
        headers: { Accept: "application/json" },
      });
      const result: unknown = await response.json();
      const ok =
        typeof result === "object" &&
        result !== null &&
        "success" in result &&
        result.success === true;
      showStatus(form, ok ? "success" : "error");
      if (ok) form.reset();
    } catch {
      showStatus(form, "error");
    } finally {
      button.disabled = false;
      button.textContent = form.dataset.submitLabel ?? "";
    }
  }

  function setupForm(): void {
    const form = document.getElementById("contact-form");
    if (!(form instanceof HTMLFormElement)) return;

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      if (!validate(form)) return;
      if (PUBLIC_WEB3FORMS_KEY === "") {
        // Endpoint not configured (no PUBLIC_WEB3FORMS_KEY) — treat as error state.
        showStatus(form, "error");
        return;
      }
      void submit(form);
    });
  }

  document.addEventListener("astro:page-load", setupForm);
</script>
